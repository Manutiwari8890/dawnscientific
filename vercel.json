{
    "rewrites": [
      {
        "source": "/product/:slug",
        "destination": "/api/product?slug=:slug"
      },
      { "source": "/(.*)", "destination": "/index.html" }
    ],
    "headers": [
    {
      "source": "/(.*).(js|css|woff2|png|jpg|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
